{
  "$schema": "https://www.getbifrost.ai/schema",
  "encryption_key": "env.BIFROST_ENCRYPTION_KEY",
  "client": {
    "drop_excess_requests": false,
    "enable_logging": true
  },
  "providers": {
    "vllm": {
      "keys": [
        {
          "name": "openai/gpt-oss-120b",
          "value": "",
          "models": ["openai/gpt-oss-120b"],
          "weight": 1.0,
          "vllm_key_config": {
            "url": "env.VLLM_GPT_OSS_URL",
            "model_name": "openai/gpt-oss-120b"
          }
        },
        {
          "name": "Qwen/Qwen3.6-27B",
          "value": "",
          "models": ["Qwen/Qwen3.6-27B"],
          "weight": 1.0,
          "vllm_key_config": {
            "url": "env.VLLM_QWEN3_URL",
            "model_name": "Qwen/Qwen3.6-27B"
          }
        },
        {
          "name": "hermes/agent",
          "value": "env.VLLM_HERMES_API_KEY",
          "models": ["hermes-agent"],
          "weight": 1.0,
          "vllm_key_config": {
            "url": "http://hermes-agent:8642",
            "model_name": "hermes-agent"
          }
        }
      ]
    }
  },
  "config_store": {
    "enabled": false
  }
}
