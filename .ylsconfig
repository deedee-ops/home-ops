{
  "ignoreFiles": [
    ".forgejo/actionlint.yaml",
    "docker/roms-server/config/roms-server.yaml",
    "docker/talos-factory/config/config.yaml",
    "kubernetes/apps/default/glance/resources/*.y*ml",
    "kubernetes/apps/default/glance/resources/widgets/*.yaml",
    "kubernetes/apps/default/searxng/resources/*.y*ml",
    "kubernetes/apps/flux-system/flux-operator/resources/config.yaml",
    "kubernetes/apps/home/frigate/resources/config.yaml",
    "kubernetes/apps/immich-system/immich/resources/config.yaml",
    "kubernetes/apps/observability/gatus/resources/config.yaml",
    "kubernetes/apps/retro/romm/resources/config.yaml",
    "kubernetes/clusters/*/values.yaml",
    "talos/*/schematic.yaml.j2"
  ],
  "allowOnlyURLs": [
    "https://www.schemastore.org",
    "https://schemas.ajgon.casa",
    "https://devenv.sh"
  ]
}
