{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      enabled: false,
      description: "Disable private registry images",
      matchDatasources: ["docker"],
      matchPackageNames: ["/registry\\.ajgon\\.casa/"],
    },
    {
      description: "Exclude packages with disabled timestamps",
      matchPackageNames: ["ghcr.io/home-operations/busybox"],
      minimumReleaseAge: null,
    },
  ],
}
