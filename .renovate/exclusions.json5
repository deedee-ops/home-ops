{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      enabled: false,
      description: "Disable private registry images",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/registry\\.ajgon\\.casa/",
        // this would also surpress "Package lookup failures" for talos/*/machineconfig.yaml,
        // when docker datasource interferes instead of using "custom.talos-factory" datasource
        "/talos\\.ajgon\\.casa/",
      ],
    },
    {
      description: "Hold influxdb at v1",
      matchPackageNames: ["/influxdb/"],
      allowedVersions: "<2.0.0",
    },
    {
      description: "Hold bifrost at v1",
      matchPackageNames: ["/bifrost/"],
      allowedVersions: "<2.0.0",
    },
  ],
}
